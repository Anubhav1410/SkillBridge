# MongoDB connection string (MongoDB Atlas or local)
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>/SkillBridge

# Server port
PORT=3000

# Frontend origin allowed by CORS
CLIENT_URL=http://localhost:5173

# Secret used to sign JWT auth tokens (use a long random string)
JWT_SECRET=your_jwt_secret_here

# Google Gemini API key - get one free at https://aistudio.google.com/apikey
GOOGLE_GENAI_API_KEY=your_google_gemini_api_key_here

# Gemini model to use (fast + free tier friendly)
GEMINI_MODEL=gemini-flash-lite-latest

# Model "thinking" budget. 0 = off (fast, ~5s). Raise for deeper reasoning (slower).
GEMINI_THINKING_BUDGET=0
